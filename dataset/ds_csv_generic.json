{
	"name": "ds_csv_generic",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_adls_gen2",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"folderName": {
				"type": "string"
			},
			"fileName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": "@{dataset().fileName}.csv",
				"folderPath": "@{dataset().folderName}",
				"fileSystem": "bronze"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "ChurnID",
				"type": "String"
			},
			{
				"name": "DateKey",
				"type": "String"
			},
			{
				"name": "CustomerKey",
				"type": "String"
			},
			{
				"name": "ProductKey",
				"type": "String"
			},
			{
				"name": "ChurnType",
				"type": "String"
			},
			{
				"name": "ChurnReason",
				"type": "String"
			},
			{
				"name": "ChurnFlag",
				"type": "String"
			},
			{
				"name": "ChurnRiskScore",
				"type": "String"
			},
			{
				"name": "MonthlyRevenue",
				"type": "String"
			}
		]
	}
}